APP_NAME=VeriFyre
APP_ENV=local
APP_KEY=
# Safe to set true for local development only. Must be false in production -
# debug pages leak stack traces, queries, and env values on errors.
APP_DEBUG=false
APP_URL=http://localhost/Verifyre_Laravel/public

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=verifyre_laravel_database
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
# Set to true in production (requires HTTPS).
SESSION_SECURE_COOKIE=null

# Used by DatabaseSeeder to set the initial superadmin password.
# Set a strong value before seeding a production database.
SUPERADMIN_DEFAULT_PASSWORD=

# ----------------------------------------------------------------
# MAIL / OTP SETTINGS
# Reyanne: fill these in with YOUR email + a Gmail "App Password"
# (not your normal Gmail password). Generate one at:
# https://myaccount.google.com/apppasswords
# (requires 2-Step Verification turned ON for your Google account)
# ----------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email_here@gmail.com
MAIL_PASSWORD=your_16_char_app_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your_email_here@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# Contact number shown in the site footer ("Contact Us")
SITE_CONTACT_NUMBER="+63 900 000 0000"
SITE_CONTACT_EMAIL="innovision.verifyre@gmail.com"

# Semaphore SMS gateway (used for SMS login OTP). Get your key at
# https://semaphore.co/
SEMAPHORE_API_KEY=
